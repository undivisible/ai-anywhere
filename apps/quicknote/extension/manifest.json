{
  "manifest_version": 3,
  "name": "quicknote",
  "version": "0.1.0",
  "description": "Take quick notes on any page, stored locally in your browser.",
  "permissions": ["storage"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "quicknote"
  },
  "web_accessible_resources": [
    {
      "resources": ["vendor/*", "src/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
